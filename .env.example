# Portfolio Admin Panel - Environment Variables
# Copy this file to .env.local and fill in the values.

# JWT secret for signing admin session tokens (Required in production, fallback in dev).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-jwt-secret-here

# GitHub Personal Access Token (PAT) with "repo" scope (Required on Vercel for live editing).
# Used to commit content updates directly back to your GitHub repository.
GITHUB_TOKEN=your-github-personal-access-token-here
