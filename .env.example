# Portfolio Admin Panel - Environment Variables
# Copy this file to .env.local and fill in the values.

# JWT secret for signing admin session tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-jwt-secret-here

# Bcrypt hash of the admin password.
# Generate with: node -e "require('bcryptjs').hash('your-password', 12).then(console.log)"
ADMIN_PASSWORD_HASH=$2a$12$...your-bcrypt-hash-here...
